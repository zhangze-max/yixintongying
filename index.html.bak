频率": "每天", "所属系统": "环保小脑-水气系统", "软件功能缺陷问题": "平台展示的站点在离线数据不准，实际依赖中联兴蔡海波线下Excel确认"}, {"序号": "28", "所属项目": "DYW环保小脑", "提交人": "雷丽怡", "名称": "危废仓库AI识别精度", "频率": "每天", "所属系统": "环保小脑-危废系统", "软件功能缺陷问题": "仓库容量AI算法仅用于演示，识别不精确，日常巡查靠人眼判断超量"}, {"序号": "29", "所属项目": "DYW环保小脑", "提交人": "雷丽怡", "名称": "省平台Cookie同步机制", "频率": "每天", "所属系统": "环保小脑-危废系统", "软件功能缺陷问题": "联单同步需手动从省固废平台取cookie，隔几天失效需重设"}, {"序号": "30", "所属项目": "DYW环保小脑", "提交人": "雷丽怡", "名称": "周报/月报自动化程度低", "频率": "每周/每月", "所属系统": "多系统（环保小脑+一体通感+海康）", "软件功能缺陷问题": "4大模块数据分散在4个以上系统，全部依赖人工汇总和Excel填写"}, {"序号": "31", "所属项目": "DYW环保小脑", "提交人": "雷丽怡", "名称": "危废仓库巡查台账人工制表", "频率": "每天", "所属系统": "环保小脑-危废系统", "软件功能缺陷问题": "每日截图→粘贴→人工填表，96+路口纯手工操作"}, {"序号": "32", "所属项目": "DYW环保小脑", "提交人": "雷丽怡", "名称": "危废视频离线跟踪", "频率": "每天", "所属系统": "海康NVR+一体通感", "软件功能缺陷问题": "仓库摄像头离线原因需人工逐台排查，无自动通知机制"}, {"序号": "33", "所属项目": "DYW环保小脑", "提交人": "雷丽怡", "名称": "应急辅助工具稳定性", "频率": "按需", "所属系统": "环保小脑-水气系统", "软件功能缺陷问题": "污染物溯源、SLAB模型在接待演示时偶尔无法正常检索或计算超时"}, {"序号": "34", "所属项目": "DYW环保小脑", "提交人": "雷丽怡", "名称": "大屏可视化数据不对", "频率": "持续", "所属系统": "环保小脑-支撑系统", "软件功能缺陷问题": "支撑系统大屏展示的部分统计数据与实际不符"}, {"序号": "35", "所属项目": "DYW环保小脑", "提交人": "雷丽怡", "名称": "服务评价表手工整理", "频率": "每月", "所属系统": "多系统+共享盘", "软件功能缺陷问题": "12个子附件需逐一从多系统复制粘贴，修改日期和内容"}, {"序号": "36", "所属项目": "中山项目", "提交人": "覃丽程", "名称": "特殊作业活动管理/票证管理", "频率": "持续", "所属系统": "智慧应急", "软件功能缺陷问题": "已根据业主要求完成了中山的特殊作业模块与省厅接口文档和AQ3064.2的差距评估：\n一、AQ3064.2涉园区平台共9项要求，6个在合同内，3个在合同外。6个合同内的需要按照规范进行完善。标记红色的字体的是缺的。需要指挥所安排产品评估并优化。\n二、文档已列明与原30871规范的升级和新增内容。作为向业主汇报的辅助材料。\n三、目前中山高频使用的2个模块，特殊作业报备和特殊作业票证管理。存在与省厅接口文档不同步，智管平台和应急后台数据不同步的情况，需要处理，已列在备注页标记黄色。\n（1）作业活动信息表。\n智管平台：\n现有系统对比省厅接口文档缺施工单位名称、施工人员编码、施工单位统一社会信用代码\n应急后台：\n报备管理（当做活动信息表）：按照省厅接口缺安全监护人员姓名、施工人员姓名、施工单位名称、施工人员编码、施工单位统一社会信用代码、作业负责人、作业负责人联系方式、是否承包商作业。\n\n按照AQ 3064.2—2025 \"工业互联网+危化安全生产\"建设规范 第2部分_特殊作业审批与作业过程管理。缺作业单位、作业级别。\n\n（2）票证管理。\n智管平台\n票证信息表：不缺。\n应急后台票证统计：\n缺作业票编号、申请部门、申请人、申请日期、作业票审批状态、施工单位统一社会信用代码、签发时间、验收时间、风险标识结果、关联的企业特殊作业、安全措施编制人、扩展信息。"}, {"序号": "37", "所属项目": "中山项目", "提交人": "覃丽程", "名称": "信息发布", "频率": "持续", "所属系统": "智慧应急", "软件功能缺陷问题": "园区要求给企业发送一些天气提醒，提供个发送窗口。"}, {"序号": "38", "所属项目": "中山项目", "提交人": "覃丽程", "名称": "合同工作量交付", "频率": "持续", "所属系统": "智慧应急/指挥中心综合系统/一网", "软件功能缺陷问题": "共146项"}, {"序号": "39", "所属项目": "中山项目", "提交人": "覃丽程", "名称": "封闭化系统同步到智慧应急", "频率": "持续", "所属系统": "智慧应急", "软件功能缺陷问题": "封闭化系统同步到智慧应急"}], "rows": [["1", "DYW安全小脑", "欧阳星", "省平台日报", "日报", "表内8个部分：\n1、3、4、5、7：省风险预警平台\n\n2、8：八柱一体通感\n\n6：智能化管控平台", "1、人工统计，需要一键导出或在一个平台查数据\n2、特殊作业统计看板问题，只统计今天的，看不了历史的\n3、省平台日报封闭化数据，都是每周找开发拿一体数据，效率慢。"], ["2", "DYW安全小脑", "欧阳星", "省平台周报", "周报", "", "人工统计"], ["3", "DYW安全小脑", "欧阳星", "省平台月报", "月报", "", "人工统计"], ["4", "DYW安全小脑", "欧阳星", "小脑运营日报", "日报", "", "人工统计"], ["5", "DYW安全小脑", "欧阳星", "小脑运营周报", "周报", "", "人工统计"], ["6", "DYW安全小脑", "欧阳星", "小脑运营月报（安全生产分析报告）", "月报", "", "人工统计"], ["7", "DYW安全小脑", "欧阳星", "环氧乙烷、苯乙烯、丁二烯指标点位表", "日报", "智能化管控平台", "人工导出统计，耗时0.5小时"], ["8", "DYW安全小脑", "欧阳星", "巡检记录（视频）", "日报", "海康视频平台", "一体通感平台数据导不不来，安全小脑视频强设备状态不准"], ["9", "DYW安全小脑", "欧阳星", "每周计划外发", "周报", "智能化管控平台", "1、人工统计，耗时需1-2小时\n2、26家人员基础数据无统计和筛选功能，都是开发导出来，运营人工处理数据，效率慢。"], ["10", "DYW安全小脑", "黄雨嫣", "日常运营", "日报", "智能化管控平台", "不支持使用企业名称进行检索，只能用企业信用代码"], ["11", "DYW港区小脑", "彭丹", "智慧港区小脑设备巡检记录", "日报", "八柱一体通感", "人工导出，处理"], ["12", "DYW港区小脑", "彭丹", "港区监控巡查台账(每周)", "周报", "港区小脑", "人工检查，登记处理"], ["13", "DYW港区小脑", "彭丹", "日常巡检检查台账(每周)", "周报", "港区小脑", "人工检查系统，登记处理"], ["14", "DYW港区小脑", "彭丹", "日常运维检查台账(每周)", "周报", "港区小脑", "人工检查，登记处理"], ["15", "DYW港区小脑", "彭丹", "视频监控设施维护更新(每周)", "周报", "港区小脑", "人工检查，登记处理"], ["16", "DYW港区小脑", "彭丹", "智慧港区小脑运营周报", "周报", "港区小脑", "人工检查，登记处理"], ["19", "古雷项目", "刘庆富", "特殊作业推送省厅统计", "日报", "特殊作业管理系统", "特殊作业推送到省厅的成功/失败/未推送数据需人工逐条统计，无自动汇总和一键导出功能，每周耗时1-2小时"], ["20", "古雷项目", "刘庆富", "人员定位在线监控", "日报", "人员定位系统", "人员定位离线状态需人工每日检查发现，无自动离线告警推送，无法实时掌握企业接入状态"], ["21", "古雷项目", "刘庆富", "视频监控掉线统计", "日报", "视频监控平台", "视频掉线需人工统计数量并逐个督促企业修复，无自动汇总和督办跟踪功能"], ["22", "古雷项目", "刘庆富", "重大危险源抽查评估", "周报", "重大危险源监测系统", "抽查合格率统计依赖人工评估和计算，无系统自动评分功能"], ["23", "古雷项目", "刘庆富", "传感器报警闭环跟踪", "日报", "工业互联网+危化安全生产平台", "报警处理闭环需人工逐条跟进，无自动超时提醒和统计功能"], ["24", "古雷项目", "刘庆富", "双重预防运行评估", "周报", "智能化管控平台", "企业双重预防运行评分（优/良/中/差）需人工统计汇总，无系统自动评估和一键导出"], ["25", "古雷项目", "刘庆富", "企业安全承诺上报监控", "日报", "智能化管控平台", "企业安全承诺每日上报情况需人工逐一确认，无未上报自动提醒"], ["26", "古雷项目", "刘庆富", "隐患整改跟踪管理", "日报", "智能化管控平台", "隐患整改状态需人工跟踪更新，无超期自动告警和统计看板"], ["27", "DYW环保小脑", "雷丽怡", "水气系统数据准确性", "每天", "环保小脑-水气系统", "平台展示的站点在离线数据不准，实际依赖中联兴蔡海波线下Excel确认"], ["28", "DYW环保小脑", "雷丽怡", "危废仓库AI识别精度", "每天", "环保小脑-危废系统", "仓库容量AI算法仅用于演示，识别不精确，日常巡查靠人眼判断超量"], ["29", "DYW环保小脑", "雷丽怡", "省平台Cookie同步机制", "每天", "环保小脑-危废系统", "联单同步需手动从省固废平台取cookie，隔几天失效需重设"], ["30", "DYW环保小脑", "雷丽怡", "周报/月报自动化程度低", "每周/每月", "多系统（环保小脑+一体通感+海康）", "4大模块数据分散在4个以上系统，全部依赖人工汇总和Excel填写"], ["31", "DYW环保小脑", "雷丽怡", "危废仓库巡查台账人工制表", "每天", "环保小脑-危废系统", "每日截图→粘贴→人工填表，96+路口纯手工操作"], ["32", "DYW环保小脑", "雷丽怡", "危废视频离线跟踪", "每天", "海康NVR+一体通感", "仓库摄像头离线原因需人工逐台排查，无自动通知机制"], ["33", "DYW环保小脑", "雷丽怡", "应急辅助工具稳定性", "按需", "环保小脑-水气系统", "污染物溯源、SLAB模型在接待演示时偶尔无法正常检索或计算超时"], ["34", "DYW环保小脑", "雷丽怡", "大屏可视化数据不对", "持续", "环保小脑-支撑系统", "支撑系统大屏展示的部分统计数据与实际不符"], ["35", "DYW环保小脑", "雷丽怡", "服务评价表手工整理", "每月", "多系统+共享盘", "12个子附件需逐一从多系统复制粘贴，修改日期和内容"], ["36", "中山项目", "覃丽程", "特殊作业活动管理/票证管理", "持续", "智慧应急", "已根据业主要求完成了中山的特殊作业模块与省厅接口文档和AQ3064.2的差距评估：\n一、AQ3064.2涉园区平台共9项要求，6个在合同内，3个在合同外。6个合同内的需要按照规范进行完善。标记红色的字体的是缺的。需要指挥所安排产品评估并优化。\n二、文档已列明与原30871规范的升级和新增内容。作为向业主汇报的辅助材料。\n三、目前中山高频使用的2个模块，特殊作业报备和特殊作业票证管理。存在与省厅接口文档不同步，智管平台和应急后台数据不同步的情况，需要处理，已列在备注页标记黄色。\n（1）作业活动信息表。\n智管平台：\n现有系统对比省厅接口文档缺施工单位名称、施工人员编码、施工单位统一社会信用代码\n应急后台：\n报备管理（当做活动信息表）：按照省厅接口缺安全监护人员姓名、施工人员姓名、施工单位名称、施工人员编码、施工单位统一社会信用代码、作业负责人、作业负责人联系方式、是否承包商作业。\n\n按照AQ 3064.2—2025 \"工业互联网+危化安全生产\"建设规范 第2部分_特殊作业审批与作业过程管理。缺作业单位、作业级别。\n\n（2）票证管理。\n智管平台\n票证信息表：不缺。\n应急后台票证统计：\n缺作业票编号、申请部门、申请人、申请日期、作业票审批状态、施工单位统一社会信用代码、签发时间、验收时间、风险标识结果、关联的企业特殊作业、安全措施编制人、扩展信息。"], ["37", "中山项目", "覃丽程", "信息发布", "持续", "智慧应急", "园区要求给企业发送一些天气提醒，提供个发送窗口。"], ["38", "中山项目", "覃丽程", "合同工作量交付", "持续", "智慧应急/指挥中心综合系统/一网", "共146项"], ["39", "中山项目", "覃丽程", "封闭化系统同步到智慧应急", "持续", "智慧应急", "封闭化系统同步到智慧应急"]]}, "异常表": {"headers": ["序号", "项目名称", "上报人", "项目阶段", "异常类型", "异常描述", "异常发生时间", "异常发现时间"], "data": [{"序号": "1", "项目名称": "DYW安全小脑", "上报人": "欧阳星", "项目阶段": "运营维护", "异常类型": "数据问题", "异常描述": "企业安全承诺数据问题：企业上传给园区的安全承诺和上传给省厅的不一致。\n1、安全承诺异常情况，25家企业一周内出现36次省厅与智管填报双数据源的数据不一致情况，差距范围为-1~201；排查后发现，其中16次不一致源于园区一级动火作业的数据库接收字段firel_number与规范字段fire1_number不一致，其余可能存在企业填报有误、待进一步排查核实。\n2、企业上传票与企业承诺票数不一致情况，已核实14家企业情况、剩余12家需进一步核实。", "异常发生时间": "2026.5.25-5.30", "异常发现时间": "46175"}, {"序号": "2", "项目名称": "DYW安全小脑", "上报人": "欧阳星", "项目阶段": "运营维护", "异常类型": "风险事件", "异常描述": "中海油惠州石化省平台每日告警，短信每日近15条通知到欧阳星手机。\n1、安全小脑接收企业点位数据3805条，经与企业现场核对，确少数据已补充，剩6个点位报警，已确认数值一致，属点位阈值问题，后续需开发更新。  \n2、省厅接收企业点位数据2060条，其中119条报警需企业与省厅核对，相关情况已反馈企业处理。", "异常发生时间": "46142", "异常发现时间": "46142"}, {"序号": "3", "项目名称": "DYW安全小脑", "上报人": "刘馨语", "项目阶段": "运营维护", "异常类型": "数据问题", "异常描述": "忠信企业推送数据不规范。\n核对忠信化工数据表，发现企业数据质量异常、不符合规范，有数据被上级单位拒收风险，已反馈企业整改。", "异常发生时间": "46163", "异常发现时间": "46176"}, {"序号": "4", "项目名称": "DYW安全小脑", "上报人": "黄雨嫣", "项目阶段": "运营维护", "异常类型": "数据问题", "异常描述": "兴达石化数据推送有异常。\n推送到省厅点位有大量缺失，且阈值存在异常，企业已多次反馈。", "异常发生时间": "46178", "异常发现时间": "46178"}, {"序号": "6", "项目名称": "古雷项目", "上报人": "刘庆富", "项目阶段": "运营维护", "异常类型": "风险事件", "异常描述": "海顺德高空AR视频监控因中沙乙烯施工挖断电缆，导致无法查看视频监控，影响园区高空瞭望能力", "异常发生时间": "2026.5.18", "异常发现时间": "2026.5.18"}, {"序号": "7", "项目名称": "古雷项目", "上报人": "刘庆富", "项目阶段": "运营维护", "异常类型": "数据问题", "异常描述": "中怡化工人员定位系统离线，影响该企业人员实时位置监控和应急疏散管理", "异常发生时间": "2026.5.18", "异常发现时间": "2026.5.18"}, {"序号": "8", "项目名称": "古雷项目", "上报人": "刘庆富", "项目阶段": "运营维护", "异常类型": "数据问题", "异常描述": "惠成新材料未推送特殊作业票证（含作业票证和附件），导致该企业特殊作业数据缺失，影响园区统计和省厅推送完整性", "异常发生时间": "2026.5.18", "异常发现时间": "2026.5.18"}, {"序号": "9", "项目名称": "古雷项目", "上报人": "刘庆富", "项目阶段": "运营维护", "异常类型": "数据问题", "异常描述": "园区特殊作业票证推送到省厅存在推送失败和未推送情况：每周约2100条中推送失败约90条、未推送约67条，成功率约92.5%", "异常发生时间": "2026.5.25", "异常发现时间": "2026.5.25"}, {"序号": "10", "项目名称": "古雷项目", "上报人": "刘庆富", "项目阶段": "运营维护", "异常类型": "风险事件", "异常描述": "重大危险源抽查合格率持续偏低：5.18-5.24合格率仅21.42%（9/42合格），5.25-5.31合格率54%（20/37合格），远低于80%标准", "异常发生时间": "2026.5.18", "异常发现时间": "2026.5.24"}, {"序号": "11", "项目名称": "古雷项目", "上报人": "刘庆富", "项目阶段": "运营维护", "异常类型": "风险事件", "异常描述": "腾龙芳烃传感器持续频繁报警：5.18-5.24产生26条低报压力报警（成品油罐区），5.25-5.31产生24条（20条压力低报+4条温度高报），因压力表损坏触发橙色预警1次", "异常发生时间": "2026.5.18", "异常发现时间": "2026.5.18"}, {"序号": "12", "项目名称": "揭阳一期项目", "上报人": "黄立泰", "项目阶段": "运营维护", "异常类型": "功能缺陷", "异常描述": "现在每天都需要重启808、809服务，且信创云的windows服务器运行不稳定，所以需要将808、809服务迁移到本地服务器", "异常发生时间": "2026.6.11", "异常发现时间": "2026.6.11"}, {"序号": "13", "项目名称": "DYW安全小脑", "上报人": "刘馨语", "项目阶段": "运营维护", "异常类型": "风险事件", "异常描述": "省厅通报情况中园区侧问题：\n（1）封闭化市局未收到（2项）：人员通行数据、车辆报警数据。此2项园区暂不具备推送条件，正在协调公安提供相关数据，已在走发函流程。\n（2）敏捷应急市局未收到（2项）：救援处置过程记录表、应急处置方案。已安排开发人员重新推送。\n（3）惠州市35家企业人员定位在线率仅有40%，省厅反馈统计逻辑为统计周期内每天有定位数据的企业数；为提高园区26家企业的省厅在线率，需有人每日核查企业的人员定位在线情况、反馈并督促企业尽量当天恢复在线。当前数据在线情况查询为26家企业逐家手动查询，建议开发统一看板。", "异常发生时间": "2026.5.25-5.30", "异常发现时间": "2026.6.12"}, {"序号": "14", "项目名称": "DYW安全小脑", "上报人": "黄雨嫣", "项目阶段": "运营维护", "异常类型": "风险事件", "异常描述": "数据库连续两周发生异常故障，导致系统崩溃", "异常发生时间": "2026.6.22", "异常发现时间": "2026.6.22"}, {"序号": "15", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "方案设计", "异常类型": "功能缺陷", "异常描述": "自动生成报告。\n\n1、要求按照省厅模版，系统能直接生成的，就直接生成日报、周报。\n【金山文档 | WPS云文档】 平台日报和周报内容\nhttps://www.kdocs.cn/l/cmEH0PjfoRuF\n2、要求实现省厅日报要求的证件到期提醒，包括安全基础管理企业许可证、特种作业操作证到期提醒。", "异常发生时间": "46115", "异常发现时间": "46115"}, {"序号": "17", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "上线部署", "异常类型": "进度延迟", "异常描述": "布控球采购进度和3号岗设备采购。\n\n【项目】中山项目\n【甲 1（火）】服务中心程秋茹 ，时间：2026年4月7日，1500\n1.问题：\n要求核对一下各项工作本周进展。\n落实移动:\n1、编写园区封闭化情况汇报(包括现状、1.5版本实施效果、未来管理规划等内容，需图文结合);\n进度：上周五已就初稿进行讨论，要求增加现有视频的监管详细内容和下一步扩区的具体实施步骤。\n暂未更新，预计周四周五能更新好。\n\n2、制定平台使用、操作培训计划4月3日前(每月不小于2次);\n进度：正常开展中，7-8日都进行了培训。\n\n3、启动园区布控球采购工作(园区2个，中科富1个);\n进度：已沟通合同只有1个布控球，指挥所已受理需求。\n\n4、计划6月启动园区3号岗升级工作，提前作准备。\n进度：已沟通指挥所已受理需求。\n\n5、与移动沟通落实:周期性开展园区智慧管控平台建设情况、使用操作演示、问题反馈完善对碰会(确定开展周期及相关内容)。\n进度：此项工作是要求每周都要跟崔主任本人汇报平台建设情况，问题等。已预约本周五下午开工作量核对会议。\n\n6、确认扩区范围后，要求移动落实园区扩区范围物理围蔽预算。\n进度：与第一项合并。会在下一步扩区规划里面写清楚。\n\n3.场合：现场沟通。\n4.情绪：无\n5.痛点：无\n6.机会：无\n\n\n拟办：\n请指挥所反馈布控球采购进度和3号岗设备采购进度给园区服务中心。", "异常发生时间": "46120", "异常发现时间": "46120"}, {"序号": "20", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "运营维护", "异常类型": "资源不足", "异常描述": "一张图对接\n【甲3（火）】中山市自然资源局张奕戈 时间：2026年4月15日，16:00\n1.问题： \n关于一张图申请对接，去省一网统管平台找不到中山市自然资源局的高清影像地图，让园区帮忙问下他们局挂载上去的数据编码和名称是什么。\n园区让联系张奕戈，张奕戈反馈路径为目录管理-共享目录-电子地图，就能找到他们局所有的地图了，让我们自己去看看要哪个，如果没有就联系翟新华（88303617）去对接。\n2.行为：上报指挥所\n3.场合：电话沟通\n4.情绪：无 \n5.痛点：无", "异常发生时间": "46127", "异常发现时间": "46127"}, {"序号": "21", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "上线部署", "异常类型": "资源不足", "异常描述": "决策视频平台用哪个？\n \n拟办：接入视频需要海康平台，中山的海康平台从2025年12月就到期了。现在有标2消防楼顶的视频需要接入，远程控制闸阀的视频需要接入，需要把海康平台续期。", "异常发生时间": "46134", "异常发现时间": "46134"}, {"序号": "22", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "运营维护", "异常类型": "资源不足", "异常描述": "公共雨水闸阀报价\n给园区报一下2个公共雨水闸阀的远程控制设备采购和接入。", "异常发生时间": "46139", "异常发现时间": "46139"}, {"序号": "23", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "运营维护", "异常类型": "沟通协作", "异常描述": "\n云MSA平台短信开通\n中山项目\n【乙1（火）】移动马钰昌 时间：2026年4月29日，9:30\n1.问题：\n沟通移动云MAS平台预计五一节后可以开通，开通需要实名，是用国科的单位名做实名吗？另外费用也是国科给吗？\n2.行为：上报指挥所\n3.场合：电话沟通\n4.情绪：无\n5.痛点：无\n\n已经问了移动，用甲方的实名，就开不了国科的发票。这个要怎么处理？", "异常发生时间": "46139", "异常发现时间": "46139"}, {"序号": "24", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "方案设计", "异常类型": "资源不足", "异常描述": "节假日安全提醒、天气提醒\n\n中山项目\n【甲1（火）】服务中心黄富明 时间：2026年4月29日，10:00\n1.问题： 园区经常需要发一些节假日安全提醒、天气提醒等给企业，涉及到短信通知和公文通知，不适合用园区封闭化公众号，需要在系统做个园区企业通知的窗口，最好就直接在企业经常用的封闭化预约和智慧应急做通知，能提醒企业查看。\n2.行为：上报指挥所\n3.场合：现场沟通\n4.情绪：无 \n5.痛点：无\n \n拟办：中山的合同内容包括公共服务，根据中山用户的使用习惯，建议把功能做在智慧应急或者封闭化预约系统。支持群发短信，支持发图文内容和园区公文，可查看历史发送内容。", "异常发生时间": "46139", "异常发现时间": "46139"}, {"序号": "25", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "方案设计", "异常类型": "功能缺陷", "异常描述": "灾害后果模型\n\n【金山文档 | WPS云文档】 中山灾害后果评估\nhttps://www.kdocs.cn/l/ce8zaqEKJkGM\n\n【金山文档 | WPS云文档】 中山三角镇高平化工园区辖区内危险化学品\nhttps://www.kdocs.cn/l/cppHRRBomKrG", "异常发生时间": "46139", "异常发现时间": "46139"}, {"序号": "26", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "上线部署", "异常类型": "资源不足", "异常描述": "恢复睡岗视频告警\n1、关于重大危险源的视频报警。目前自己装的睡岗的盒子数据从2025年12月开始就断了。火点和烟雾监测在省厅的分析盒子里面，开发看下接几条过来演示行不行。", "异常发生时间": "46153", "异常发现时间": "46153"}, {"序号": "27", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "开发测试", "异常类型": "资源不足", "异常描述": "央督检查-危废数据完善\n\n中山项目\n【甲1（火）】服务中心程秋茹 时间：2026年5月19日，10:00\n1.问题：\n跟进昨日央督问题进度：\n1）第五点第4点，要求写成材料回复。\n2）设备联网问题，昨日已联系标2处理好标站离线问题。\n3）市固废接口断了，今日已恢复，数据正常。\n4）要求录入环保台账，目前已提供转运联单台账，因环保系统有问题废物清单录入不进去，需要开发处理。\n还有产废、处置台账等需要录入，可能还有录入问题，需要开发保障。\n5）在预警规则通知人那里再增加镇执法的3个人，因环保系统没有地方维护组织和联系人，需要开发从智慧应急同步。\n2.行为：上报指挥所\n3.场合：现场沟通\n4.情绪：无 \n5.痛点：无\n\n拟办：请指挥所安排开发处理一下央督检查涉及的问题。", "异常发生时间": "46160", "异常发现时间": "46160"}, {"序号": "28", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "开发测试", "异常类型": "资源不足", "异常描述": "央督检查-危废数据完善\n\n中山项目\n【甲1（火）】服务中心程秋茹 时间：2026年5月19日，16:00\n1.问题：\n秋茹反馈市生态环境分局回复有转运联单相关数据，要求核对一下字段是否满足要求。\n核对后已反馈缺了部分关键字段：废物类别/废物代码/废物名称/转移数量/确认数量/转移方式/车牌号/承运人/接收单位名称。\n \n2.行为：上报指挥所\n3.场合：现场沟通\n4.情绪：无 \n5.痛点：无\n \n拟办：\n中山的固废数据目前出入库台账对接是对的，按照系统数据来看缺产废、转运、处置台账。已核对之前对接过的产废台账实际跟我们系统的产废台账字段不一致，这次找市局补数据源干脆一次性补齐，需要固废系统的产品出一份产品设计说明材料和数据对接说明材料，写清楚一下危险废物管理里面的各个模块都要去哪里对接数据，跟危废处置管理里面的台账有什么区别，有什么注意事项。仓库管理里面的出入库台账为什么不能根据前面已经对接的数据自动入库。\n\n", "异常发生时间": "46161", "异常发现时间": "46161"}, {"序号": "29", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "运营维护", "异常类型": "资源不足", "异常描述": "要求周末/节假日值班\n\n5月25日8：30综合管理组黄富明组织召开综合管理组例会，记录如下：\n一、园区已基本确定扩区到865亩，接下来会跟很多第三方单位对接进行园区扩区认定工作，综合管理组的工作拟交接给吴崇侠。\n二、总结近期平台建设工作。\n二期平台建设工作实现从有到用，接下来重点从用到优。目前综合管理组已经通过平台实现省应急厅日报/周报/月报报送，让平台有效使用，充分发挥平台价值，让各级领导检查的时候有数据可看。目前已上线1个web端的平台、2个APP和1个移动端小程序，大家在使用的过程中提了很多意见，系统有很大优化，目前安全检查也淘汰了原纸质版本，实现了智能化。\n三、提出技术单位六月起周六日和节假期也要值守。\n因扩区需要的资料很多，周六日也有专家或者领导过来检查，六月起周六日和节假日技术单位也要有人在现场值班，要教会综合组的人汇报系统。人员不够就增加人手。现场已反馈这点我要汇报上去才能回复。\n四、吴崇侠提出要建设园区基础设施一张图，把园区各类设施都标注在地图上。\n已回复目前已经有很多一张图，分了不同的业务进行呈现，如果全部都铺在地图上，满满当当的也不好看。下来以后可以跟冯小容对接一下，基本都有，缺的可以补。", "异常发生时间": "46167", "异常发现时间": "46167"}, {"序号": "30", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "方案设计", "异常类型": "功能缺陷", "异常描述": " 央督检查-危废数据完善\n\n中山项目\n【甲1（火）】服务中心 程秋茹 时间：2026年5月26日 15:00\n1.问题：\n下午崔主任又提了一下那于接那个固废平台的，你有空就继续跟进一下，央督检查还在继续，要保障好。\n2.行为：\n一问给谁看：上级检查。\n二问预期效果：实现固废智能监管\n三问前提条件：需要从市生态环境局对接数据\n3.场合：现场沟通\n4.情绪：无\n5.痛点：无\n6.机会：无\n\n已回复最近都在忙市应急局接待的问题，上周核对了之前从市局接的台账，出入库台账只有中晟自产的出入库，没有其他企业转运的，另外几家企业只有约克夏有数据，数据不完整。产废台账接错了，字段对不上，市局接口也没数据。\n现在准备先去省平台核对一下数据源，核对好字段再跟市局沟通对接哪些，固废平台数据关联性比较强，缺了数据会导致业务没办法闭环。", "异常发生时间": "46167", "异常发现时间": "46167"}, {"序号": "31", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "运营维护", "异常类型": "风险事件", "异常描述": "\n中山运维\n中山项目\n【甲1（火）】服务中心 黄富明 时间：2026年5月27日 11:00\n1.问题：\n服务中心黄富明在给某个扩区的第三方简单介绍一下系统的时候，系统出现了故障，报错无法进入。\n现场已解释最近网络不稳定，光纤被挖断了导致的。\n2.行为：\n一问给谁看：服务中心/检查人员等\n二问预期效果：系统稳定\n三问前提条件：需要解决系统偶尔打不开的问题\n3.场合：现场沟通\n4.情绪：无\n5.痛点：无\n6.机会：无\n\n今天出现的故障大概10分钟左右，内网地址可以打开，域名地址不行。已联系移动阿文，截图回复网络不曾出现中断，要求核实是不是设备使用率超了。\n联系了卢工帮忙看下，卢工反馈不像是网络问题，反馈让张玉飞排查一下。\n张玉飞排查结果，是转到机房服务端口超时，那可能是网络问题也可能是我们服务问题，下次出现故障再排查。\n\n其他方的问题可以我去联系处理，我们内部谁处理故障需要安排好责任人，避免有重要演示接待的时候出现故障影响客户NPS。", "异常发生时间": "46167", "异常发现时间": "46167"}, {"序号": "32", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "方案设计", "异常类型": "进度延迟", "异常描述": "\n消防需求\n 中山项目\n【甲1（火）】服务中心 崔主任、李文远；消防大队范队等 时间：2026年5月28日 16:00-17:30\n1.问题：\n一、消防大队范队反馈移动是不是不想做他们的项目，谈了三四次，几个月了，推进事项毫无进展。\n上次来了个工程师一看就是不想做，开口就是要钱，这也做不了那也做不了。介绍消防大队这边要推进项目，做好以后也是亮点，可以给其他消防大队推广，对我们来说也是绩效，也是亮点。不要只关心园区的项目，忽视他们的需求。\n二、崔主任问为什么没响应，现场已跟领导们道歉，是我的问题，我忙忘记了。\n三、范队要求把上次沟通的事项列出来，一项项的现在就谈好，列好项目推进表。\n四、现场沟通事项：\n1、园区已授权给消防大队开通现有系统账号，先实现能看到已经有的。计划一周内完成，下周五之前给消防大队开好智慧应急系统账号，并教消防大队的人使用。\n2、消防提的定制页面以及接入企业消防设备，已沟通确实是需要成本，计划一周出方案，下周五之前给方案。\n根据方案再讨论怎么实现。一些简单的满足对接条件的物联网设备可以先接上来。\n3、消防提及新需求。\n（1）要能跟企业的中控室直连，应急状态下能直接指挥中控室。\n（2）要接入消防车的GPS和液位传感器。\n2.行为：\n一问给谁看：给消防大队。\n二问预期效果：有新商机。\n三问前提条件：前提迟迟未提供方案，消防大队范队已经有点生气，需要尽快提供方案。\n3.场合：现场沟通\n4.情绪：无\n5.痛点：无\n6.机会：无", "异常发生时间": "46169", "异常发现时间": "46169"}, {"序号": "33", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "运营维护", "异常类型": "资源不足", "异常描述": "进度计划表\n【甲1（火）】服务中心程秋茹 时间：2026年6月15日 16:00\n1.问题：\n关于接下来信息化的工作，要求用表列个计划出来，包括工作内容、预计开展时间、预计完成时间，后续按这个表来催进度。\n已回复：目前还只有实施内容，计划完成时间待定，本周内可以给。\n2.行为：\n一问给谁看：给园区\n二问预期效果：按计划推进项目验收\n三问前提条件：无\n3.场合：微信沟通\n4.情绪：无\n5.痛点：无\n6.机会：无", "异常发生时间": "46188", "异常发现时间": "46188"}, {"序号": "34", "项目名称": "中山项目", "上报人": "覃丽程", "项目阶段": "运营维护", "异常类型": "风险事件", "异常描述": "中山运维\n【甲1（火）】高平化工园区服务中心黄富明 时间：2026年6月17日 17:00\n1.问题：\n今天市安委办下来复核封闭化预约问题，给第三方单位演示的时候系统转了1分多钟才出来，上次财审来的时候也是这样的，你们要检查一下这个问题。\n2.行为：\n一问给谁看：给园区\n二问预期效果：排查并解决系统响应慢问题，确保演示和检查时系统流畅\n三问前提条件：无\n一提炼动议目的：消除演示卡顿隐患，避免影响后续检查和验收\n3.场合：现场反馈\n4.情绪：不满\n5.痛点：系统演示时加载超1分钟，影响园区形象，财审和安委办两次出现问题\n6.机会：无", "异常发生时间": "46190", "异常发现时间": "46190"}], "rows": [["1", "DYW安全小脑", "欧阳星", "运营维护", "数据问题", "企业安全承诺数据问题：企业上传给园区的安全承诺和上传给省厅的不一致。\n1、安全承诺异常情况，25家企业一周内出现36次省厅与智管填报双数据源的数据不一致情况，差距范围为-1~201；排查后发现，其中16次不一致源于园区一级动火作业的数据库接收字段firel_number与规范字段fire1_number不一致，其余可能存在企业填报有误、待进一步排查核实。\n2、企业上传票与企业承诺票数不一致情况，已核实14家企业情况、剩余12家需进一步核实。", "2026.5.25-5.30", "46175"], ["2", "DYW安全小脑", "欧阳星", "运营维护", "风险事件", "中海油惠州石化省平台每日告警，短信每日近15条通知到欧阳星手机。\n1、安全小脑接收企业点位数据3805条，经与企业现场核对，确少数据已补充，剩6个点位报警，已确认数值一致，属点位阈值问题，后续需开发更新。  \n2、省厅接收企业点位数据2060条，其中119条报警需企业与省厅核对，相关情况已反馈企业处理。", "46142", "46142"], ["3", "DYW安全小脑", "刘馨语", "运营维护", "数据问题", "忠信企业推送数据不规范。\n核对忠信化工数据表，发现企业数据质量异常、不符合规范，有数据被上级单位拒收风险，已反馈企业整改。", "46163", "46176"], ["4", "DYW安全小脑", "黄雨嫣", "运营维护", "数据问题", "兴达石化数据推送有异常。\n推送到省厅点位有大量缺失，且阈值存在异常，企业已多次反馈。", "46178", "46178"], ["6", "古雷项目", "刘庆富", "运营维护", "风险事件", "海顺德高空AR视频监控因中沙乙烯施工挖断电缆，导致无法查看视频监控，影响园区高空瞭望能力", "2026.5.18", "2026.5.18"], ["7", "古雷项目", "刘庆富", "运营维护", "数据问题", "中怡化工人员定位系统离线，影响该企业人员实时位置监控和应急疏散管理", "2026.5.18", "2026.5.18"], ["8", "古雷项目", "刘庆富", "运营维护", "数据问题", "惠成新材料未推送特殊作业票证（含作业票证和附件），导致该企业特殊作业数据缺失，影响园区统计和省厅推送完整性", "2026.5.18", "2026.5.18"], ["9", "古雷项目", "刘庆富", "运营维护", "数据问题", "园区特殊作业票证推送到省厅存在推送失败和未推送情况：每周约2100条中推送失败约90条、未推送约67条，成功率约92.5%", "2026.5.25", "2026.5.25"], ["10", "古雷项目", "刘庆富", "运营维护", "风险事件", "重大危险源抽查合格率持续偏低：5.18-5.24合格率仅21.42%（9/42合格），5.25-5.31合格率54%（20/37合格），远低于80%标准", "2026.5.18", "2026.5.24"], ["11", "古雷项目", "刘庆富", "运营维护", "风险事件", "腾龙芳烃传感器持续频繁报警：5.18-5.24产生26条低报压力报警（成品油罐区），5.25-5.31产生24条（20条压力低报+4条温度高报），因压力表损坏触发橙色预警1次", "2026.5.18", "2026.5.18"], ["12", "揭阳一期项目", "黄立泰", "运营维护", "功能缺陷", "现在每天都需要重启808、809服务，且信创云的windows服务器运行不稳定，所以需要将808、809服务迁移到本地服务器", "2026.6.11", "2026.6.11"], ["13", "DYW安全小脑", "刘馨语", "运营维护", "风险事件", "省厅通报情况中园区侧问题：\n（1）封闭化市局未收到（2项）：人员通行数据、车辆报警数据。此2项园区暂不具备推送条件，正在协调公安提供相关数据，已在走发函流程。\n（2）敏捷应急市局未收到（2项）：救援处置过程记录表、应急处置方案。已安排开发人员重新推送。\n（3）惠州市35家企业人员定位在线率仅有40%，省厅反馈统计逻辑为统计周期内每天有定位数据的企业数；为提高园区26家企业的省厅在线率，需有人每日核查企业的人员定位在线情况、反馈并督促企业尽量当天恢复在线。当前数据在线情况查询为26家企业逐家手动查询，建议开发统一看板。", "2026.5.25-5.30", "2026.6.12"], ["14", "DYW安全小脑", "黄雨嫣", "运营维护", "风险事件", "数据库连续两周发生异常故障，导致系统崩溃", "2026.6.22", "2026.6.22"], ["15", "中山项目", "覃丽程", "方案设计", "功能缺陷", "自动生成报告。\n\n1、要求按照省厅模版，系统能直接生成的，就直接生成日报、周报。\n【金山文档 | WPS云文档】 平台日报和周报内容\nhttps://www.kdocs.cn/l/cmEH0PjfoRuF\n2、要求实现省厅日报要求的证件到期提醒，包括安全基础管理企业许可证、特种作业操作证到期提醒。", "46115", "46115"], ["17", "中山项目", "覃丽程", "上线部署", "进度延迟", "布控球采购进度和3号岗设备采购。\n\n【项目】中山项目\n【甲 1（火）】服务中心程秋茹 ，时间：2026年4月7日，1500\n1.问题：\n要求核对一下各项工作本周进展。\n落实移动:\n1、编写园区封闭化情况汇报(包括现状、1.5版本实施效果、未来管理规划等内容，需图文结合);\n进度：上周五已就初稿进行讨论，要求增加现有视频的监管详细内容和下一步扩区的具体实施步骤。\n暂未更新，预计周四周五能更新好。\n\n2、制定平台使用、操作培训计划4月3日前(每月不小于2次);\n进度：正常开展中，7-8日都进行了培训。\n\n3、启动园区布控球采购工作(园区2个，中科富1个);\n进度：已沟通合同只有1个布控球，指挥所已受理需求。\n\n4、计划6月启动园区3号岗升级工作，提前作准备。\n进度：已沟通指挥所已受理需求。\n\n5、与移动沟通落实:周期性开展园区智慧管控平台建设情况、使用操作演示、问题反馈完善对碰会(确定开展周期及相关内容)。\n进度：此项工作是要求每周都要跟崔主任本人汇报平台建设情况，问题等。已预约本周五下午开工作量核对会议。\n\n6、确认扩区范围后，要求移动落实园区扩区范围物理围蔽预算。\n进度：与第一项合并。会在下一步扩区规划里面写清楚。\n\n3.场合：现场沟通。\n4.情绪：无\n5.痛点：无\n6.机会：无\n\n\n拟办：\n请指挥所反馈布控球采购进度和3号岗设备采购进度给园区服务中心。", "46120", "46120"], ["20", "中山项目", "覃丽程", "运营维护", "资源不足", "一张图对接\n【甲3（火）】中山市自然资源局张奕戈 时间：2026年4月15日，16:00\n1.问题： \n关于一张图申请对接，去省一网统管平台找不到中山市自然资源局的高清影像地图，让园区帮忙问下他们局挂载上去的数据编码和名称是什么。\n园区让联系张奕戈，张奕戈反馈路径为目录管理-共享目录-电子地图，就能找到他们局所有的地图了，让我们自己去看看要哪个，如果没有就联系翟新华（88303617）去对接。\n2.行为：上报指挥所\n3.场合：电话沟通\n4.情绪：无 \n5.痛点：无", "46127", "46127"], ["21", "中山项目", "覃丽程", "上线部署", "资源不足", "决策视频平台用哪个？\n \n拟办：接入视频需要海康平台，中山的海康平台从2025年12月就到期了。现在有标2消防楼顶的视频需要接入，远程控制闸阀的视频需要接入，需要把海康平台续期。", "46134", "46134"], ["22", "中山项目", "覃丽程", "运营维护", "资源不足", "公共雨水闸阀报价\n给园区报一下2个公共雨水闸阀的远程控制设备采购和接入。", "46139", "46139"], ["23", "中山项目", "覃丽程", "运营维护", "沟通协作", "\n云MSA平台短信开通\n中山项目\n【乙1（火）】移动马钰昌 时间：2026年4月29日，9:30\n1.问题：\n沟通移动云MAS平台预计五一节后可以开通，开通需要实名，是用国科的单位名做实名吗？另外费用也是国科给吗？\n2.行为：上报指挥所\n3.场合：电话沟通\n4.情绪：无\n5.痛点：无\n\n已经问了移动，用甲方的实名，就开不了国科的发票。这个要怎么处理？", "46139", "46139"], ["24", "中山项目", "覃丽程", "方案设计", "资源不足", "节假日安全提醒、天气提醒\n\n中山项目\n【甲1（火）】服务中心黄富明 时间：2026年4月29日，10:00\n1.问题： 园区经常需要发一些节假日安全提醒、天气提醒等给企业，涉及到短信通知和公文通知，不适合用园区封闭化公众号，需要在系统做个园区企业通知的窗口，最好就直接在企业经常用的封闭化预约和智慧应急做通知，能提醒企业查看。\n2.行为：上报指挥所\n3.场合：现场沟通\n4.情绪：无 \n5.痛点：无\n \n拟办：中山的合同内容包括公共服务，根据中山用户的使用习惯，建议把功能做在智慧应急或者封闭化预约系统。支持群发短信，支持发图文内容和园区公文，可查看历史发送内容。", "46139", "46139"], ["25", "中山项目", "覃丽程", "方案设计", "功能缺陷", "灾害后果模型\n\n【金山文档 | WPS云文档】 中山灾害后果评估\nhttps://www.kdocs.cn/l/ce8zaqEKJkGM\n\n【金山文档 | WPS云文档】 中山三角镇高平化工园区辖区内危险化学品\nhttps://www.kdocs.cn/l/cppHRRBomKrG", "46139", "46139"], ["26", "中山项目", "覃丽程", "上线部署", "资源不足", "恢复睡岗视频告警\n1、关于重大危险源的视频报警。目前自己装的睡岗的盒子数据从2025年12月开始就断了。火点和烟雾监测在省厅的分析盒子里面，开发看下接几条过来演示行不行。", "46153", "46153"], ["27", "中山项目", "覃丽程", "开发测试", "资源不足", "央督检查-危废数据完善\n\n中山项目\n【甲1（火）】服务中心程秋茹 时间：2026年5月19日，10:00\n1.问题：\n跟进昨日央督问题进度：\n1）第五点第4点，要求写成材料回复。\n2）设备联网问题，昨日已联系标2处理好标站离线问题。\n3）市固废接口断了，今日已恢复，数据正常。\n4）要求录入环保台账，目前已提供转运联单台账，因环保系统有问题废物清单录入不进去，需要开发处理。\n还有产废、处置台账等需要录入，可能还有录入问题，需要开发保障。\n5）在预警规则通知人那里再增加镇执法的3个人，因环保系统没有地方维护组织和联系人，需要开发从智慧应急同步。\n2.行为：上报指挥所\n3.场合：现场沟通\n4.情绪：无 \n5.痛点：无\n\n拟办：请指挥所安排开发处理一下央督检查涉及的问题。", "46160", "46160"], ["28", "中山项目", "覃丽程", "开发测试", "资源不足", "央督检查-危废数据完善\n\n中山项目\n【甲1（火）】服务中心程秋茹 时间：2026年5月19日，16:00\n1.问题：\n秋茹反馈市生态环境分局回复有转运联单相关数据，要求核对一下字段是否满足要求。\n核对后已反馈缺了部分关键字段：废物类别/废物代码/废物名称/转移数量/确认数量/转移方式/车牌号/承运人/接收单位名称。\n \n2.行为：上报指挥所\n3.场合：现场沟通\n4.情绪：无 \n5.痛点：无\n \n拟办：\n中山的固废数据目前出入库台账对接是对的，按照系统数据来看缺产废、转运、处置台账。已核对之前对接过的产废台账实际跟我们系统的产废台账字段不一致，这次找市局补数据源干脆一次性补齐，需要固废系统的产品出一份产品设计说明材料和数据对接说明材料，写清楚一下危险废物管理里面的各个模块都要去哪里对接数据，跟危废处置管理里面的台账有什么区别，有什么注意事项。仓库管理里面的出入库台账为什么不能根据前面已经对接的数据自动入库。\n\n", "46161", "46161"], ["29", "中山项目", "覃丽程", "运营维护", "资源不足", "要求周末/节假日值班\n\n5月25日8：30综合管理组黄富明组织召开综合管理组例会，记录如下：\n一、园区已基本确定扩区到865亩，接下来会跟很多第三方单位对接进行园区扩区认定工作，综合管理组的工作拟交接给吴崇侠。\n二、总结近期平台建设工作。\n二期平台建设工作实现从有到用，接下来重点从用到优。目前综合管理组已经通过平台实现省应急厅日报/周报/月报报送，让平台有效使用，充分发挥平台价值，让各级领导检查的时候有数据可看。目前已上线1个web端的平台、2个APP和1个移动端小程序，大家在使用的过程中提了很多意见，系统有很大优化，目前安全检查也淘汰了原纸质版本，实现了智能化。\n三、提出技术单位六月起周六日和节假期也要值守。\n因扩区需要的资料很多，周六日也有专家或者领导过来检查，六月起周六日和节假日技术单位也要有人在现场值班，要教会综合组的人汇报系统。人员不够就增加人手。现场已反馈这点我要汇报上去才能回复。\n四、吴崇侠提出要建设园区基础设施一张图，把园区各类设施都标注在地图上。\n已回复目前已经有很多一张图，分了不同的业务进行呈现，如果全部都铺在地图上，满满当当的也不好看。下来以后可以跟冯小容对接一下，基本都有，缺的可以补。", "46167", "46167"], ["30", "中山项目", "覃丽程", "方案设计", "功能缺陷", " 央督检查-危废数据完善\n\n中山项目\n【甲1（火）】服务中心 程秋茹 时间：2026年5月26日 15:00\n1.问题：\n下午崔主任又提了一下那于接那个固废平台的，你有空就继续跟进一下，央督检查还在继续，要保障好。\n2.行为：\n一问给谁看：上级检查。\n二问预期效果：实现固废智能监管\n三问前提条件：需要从市生态环境局对接数据\n3.场合：现场沟通\n4.情绪：无\n5.痛点：无\n6.机会：无\n\n已回复最近都在忙市应急局接待的问题，上周核对了之前从市局接的台账，出入库台账只有中晟自产的出入库，没有其他企业转运的，另外几家企业只有约克夏有数据，数据不完整。产废台账接错了，字段对不上，市局接口也没数据。\n现在准备先去省平台核对一下数据源，核对好字段再跟市局沟通对接哪些，固废平台数据关联性比较强，缺了数据会导致业务没办法闭环。", "46167", "46167"], ["31", "中山项目", "覃丽程", "运营维护", "风险事件", "\n中山运维\n中山项目\n【甲1（火）】服务中心 黄富明 时间：2026年5月27日 11:00\n1.问题：\n服务中心黄富明在给某个扩区的第三方简单介绍一下系统的时候，系统出现了故障，报错无法进入。\n现场已解释最近网络不稳定，光纤被挖断了导致的。\n2.行为：\n一问给谁看：服务中心/检查人员等\n二问预期效果：系统稳定\n三问前提条件：需要解决系统偶尔打不开的问题\n3.场合：现场沟通\n4.情绪：无\n5.痛点：无\n6.机会：无\n\n今天出现的故障大概10分钟左右，内网地址可以打开，域名地址不行。已联系移动阿文，截图回复网络不曾出现中断，要求核实是不是设备使用率超了。\n联系了卢工帮忙看下，卢工反馈不像是网络问题，反馈让张玉飞排查一下。\n张玉飞排查结果，是转到机房服务端口超时，那可能是网络问题也可能是我们服务问题，下次出现故障再排查。\n\n其他方的问题可以我去联系处理，我们内部谁处理故障需要安排好责任人，避免有重要演示接待的时候出现故障影响客户NPS。", "46167", "46167"], ["32", "中山项目", "覃丽程", "方案设计", "进度延迟", "\n消防需求\n 中山项目\n【甲1（火）】服务中心 崔主任、李文远；消防大队范队等 时间：2026年5月28日 16:00-17:30\n1.问题：\n一、消防大队范队反馈移动是不是不想做他们的项目，谈了三四次，几个月了，推进事项毫无进展。\n上次来了个工程师一看就是不想做，开口就是要钱，这也做不了那也做不了。介绍消防大队这边要推进项目，做好以后也是亮点，可以给其他消防大队推广，对我们来说也是绩效，也是亮点。不要只关心园区的项目，忽视他们的需求。\n二、崔主任问为什么没响应，现场已跟领导们道歉，是我的问题，我忙忘记了。\n三、范队要求把上次沟通的事项列出来，一项项的现在就谈好，列好项目推进表。\n四、现场沟通事项：\n1、园区已授权给消防大队开通现有系统账号，先实现能看到已经有的。计划一周内完成，下周五之前给消防大队开好智慧应急系统账号，并教消防大队的人使用。\n2、消防提的定制页面以及接入企业消防设备，已沟通确实是需要成本，计划一周出方案，下周五之前给方案。\n根据方案再讨论怎么实现。一些简单的满足对接条件的物联网设备可以先接上来。\n3、消防提及新需求。\n（1）要能跟企业的中控室直连，应急状态下能直接指挥中控室。\n（2）要接入消防车的GPS和液位传感器。\n2.行为：\n一问给谁看：给消防大队。\n二问预期效果：有新商机。\n三问前提条件：前提迟迟未提供方案，消防大队范队已经有点生气，需要尽快提供方案。\n3.场合：现场沟通\n4.情绪：无\n5.痛点：无\n6.机会：无", "46169", "46169"], ["33", "中山项目", "覃丽程", "运营维护", "资源不足", "进度计划表\n【甲1（火）】服务中心程秋茹 时间：2026年6月15日 16:00\n1.问题：\n关于接下来信息化的工作，要求用表列个计划出来，包括工作内容、预计开展时间、预计完成时间，后续按这个表来催进度。\n已回复：目前还只有实施内容，计划完成时间待定，本周内可以给。\n2.行为：\n一问给谁看：给园区\n二问预期效果：按计划推进项目验收\n三问前提条件：无\n3.场合：微信沟通\n4.情绪：无\n5.痛点：无\n6.机会：无", "46188", "46188"], ["34", "中山项目", "覃丽程", "运营维护", "风险事件", "中山运维\n【甲1（火）】高平化工园区服务中心黄富明 时间：2026年6月17日 17:00\n1.问题：\n今天市安委办下来复核封闭化预约问题，给第三方单位演示的时候系统转了1分多钟才出来，上次财审来的时候也是这样的，你们要检查一下这个问题。\n2.行为：\n一问给谁看：给园区\n二问预期效果：排查并解决系统响应慢问题，确保演示和检查时系统流畅\n三问前提条件：无\n一提炼动议目的：消除演示卡顿隐患，避免影响后续检查和验收\n3.场合：现场反馈\n4.情绪：不满\n5.痛点：系统演示时加载超1分钟，影响园区形象，财审和安委办两次出现问题\n6.机会：无", "46190", "46190"]]}, "报表清单": {"headers": ["所属园区", "报告名称", "频率", "来源"], "data": [], "rows": []}, "积分表": {"headers": ["姓名", "差距表积分", "异常表积分", "自评表积分", "总积分"], "data": [{"姓名": "欧阳星", "差距表积分": "9", "异常表积分": "2", "自评表积分": "9", "总积分": "20"}, {"姓名": "刘庆富", "差距表积分": "8", "异常表积分": "6", "自评表积分": "8", "总积分": "22"}, {"姓名": "覃丽程", "差距表积分": "4", "异常表积分": "17", "自评表积分": "0", "总积分": "21"}, {"姓名": "彭丹", "差距表积分": "6", "异常表积分": "0", "自评表积分": "6", "总积分": "12"}, {"姓名": "黄立泰", "差距表积分": "0", "异常表积分": "1", "自评表积分": "0", "总积分": "1"}, {"姓名": "黄雨嫣", "差距表积分": "1", "异常表积分": "2", "自评表积分": "0", "总积分": "3"}, {"姓名": "雷丽怡", "差距表积分": "9", "异常表积分": "0", "自评表积分": "12", "总积分": "21"}, {"姓名": "崔洪醒", "差距表积分": "0", "异常表积分": "0", "自评表积分": "0", "总积分": "0"}, {"姓名": "林泽坤", "差距表积分": "0", "异常表积分": "0", "自评表积分": "0", "总积分": "0"}, {"姓名": "冯小容", "差距表积分": "0", "异常表积分": "0", "自评表积分": "23", "总积分": "23"}, {"姓名": "刘馨语", "差距表积分": "0", "异常表积分": "2", "自评表积分": "0", "总积分": "2"}, {"姓名": "张泽稷", "差距表积分": "0", "异常表积分": "0", "自评表积分": "0", "总积分": "0"}, {"姓名": "钟瑜均", "差距表积分": "0", "异常表积分": "0", "自评表积分": "0", "总积分": "0"}, {"姓名": "孙荣杰", "差距表积分": "0", "异常表积分": "0", "自评表积分": "0", "总积分": "0"}, {"姓名": "邱惠新", "差距表积分": "0", "异常表积分": "0", "自评表积分": "0", "总积分": "0"}, {"姓名": "刘云丹", "差距表积分": "0", "异常表积分": "0", "自评表积分": "0", "总积分": "0"}, {"姓名": "李荣拨", "差距表积分": "0", "异常表积分": "0", "自评表积分": "0", "总积分": "0"}], "personnel": ["欧阳星", "刘庆富", "覃丽程", "彭丹", "黄立泰", "黄雨嫣", "雷丽怡", "崔洪醒", "林泽坤", "冯小容", "刘馨语", "张泽稷", "钟瑜均", "孙荣杰", "邱惠新", "刘云丹", "李荣拨"], "rows": [["欧阳星", "9", "2", "9", "20"], ["刘庆富", "8", "6", "8", "22"], ["覃丽程", "4", "17", "0", "21"], ["彭丹", "6", "0", "6", "12"], ["黄立泰", "0", "1", "0", "1"], ["黄雨嫣", "1", "2", "0", "3"], ["雷丽怡", "9", "0", "12", "21"], ["崔洪醒", "0", "0", "0", "0"], ["林泽坤", "0", "0", "0", "0"], ["冯小容", "0", "0", "23", "23"], ["刘馨语", "0", "2", "0", "2"], ["张泽稷", "0", "0", "0", "0"], ["钟瑜均", "0", "0", "0", "0"], ["孙荣杰", "0", "0", "0", "0"], ["邱惠新", "0", "0", "0", "0"], ["刘云丹", "0", "0", "0", "0"], ["李荣拨", "0", "0", "0", "0"]]}}, "sync_status": "stale"};var currentSort={table:null,col:null,asc:true};var expandedRows=new Set();
function render(){
  if(!DATA)return;
  var ss=DATA.sheets,zr=ss["自评表"].rows||[],cr=ss["差距表"].rows||[],yr=ss["异常表"].rows||[],br=ss["报表清单"].rows||[],jr=ss["积分表"].rows||[];
  // Scoreboard
  document.getElementById("sbt").textContent=jr.length;var sc=jr.filter(function(r){return parseInt(r[4]||0)>0});document.getElementById("sbp").textContent=sc.length;
  sc.sort(function(a,b){return parseInt(b[4]||0)-parseInt(a[4]||0)});
  var tiers=["gold","silver","bronze","",""],icons=["🥇","🥈","🥉"];
  var colors=["#f0c850","#8899aa","#c8943a","#3b6df0","#3b6df0"];
  var out=[],prevTotal=-1,dispRank=0;
  for(var i=0;i<Math.min(sc.length,5);i++){var nm=sc[i][0]||"",tot=parseInt(sc[i][4]||0);if(tot!==prevTotal){dispRank=i+1;prevTotal=tot}var t=tiers[i]||"";out.push('<div class="person'+ (t?" "+t:"")+'"><div class="p-avatar" style="background:'+colors[i]+'">'+nm.slice(-1)+'</div><div class="p-name">'+(i<3?icons[i]:i+1)+' '+nm+'</div><div class="p-title">第'+dispRank+'名</div><div class="p-score">'+tot+' 分</div></div>')}
  document.getElementById("podium").innerHTML=out.join("");
  // Overview
  var proj={};zr.forEach(function(r){var p=r[1],pe=r[2],f=r[6];if(!p||p==="项目名称")return;if(!proj[p])proj[p]={people:new Set(),d:0,w:0,m:0,an:0,ga:0};proj[p].people.add(pe);var fs=String(f);if(fs.indexOf("天")>=0||fs.indexOf("日报")>=0)proj[p].d++;else if(fs.indexOf("周")>=0||fs.indexOf("周报")>=0)proj[p].w++;else if(fs.indexOf("月")>=0||fs.indexOf("月报")>=0)proj[p].m++});
  yr.forEach(function(r){var p=r[1];if(p&&proj[p])proj[p].an++});cr.forEach(function(r){var p=r[1];if(p&&proj[p])proj[p].ga++});
  var ov=[];Object.keys(proj).forEach(function(p){var o=proj[p];ov.push('<div class="ov-card"><div class="ov-header"><span class="ov-name">'+p+'</span><span class="ov-people">'+Array.from(o.people).join(" · ")+'</span></div><div class="ov-metrics"><div class="ov-metric"><span class="val" style="color:var(--blue)">'+o.d+'</span><span class="lbl">日报</span></div><div class="ov-metric"><span class="val" style="color:var(--purple)">'+o.w+'</span><span class="lbl">周报</span></div><div class="ov-metric"><span class="val" style="color:var(--green)">'+o.m+'</span><span class="lbl">月报</span></div><div class="ov-metric"><span class="val" style="color:var(--red)">'+o.an+'</span><span class="lbl">异常</span></div><div class="ov-metric"><span class="val" style="color:var(--amber)">'+o.ga+'</span><span class="lbl">差距</span></div></div></div>')});
  document.getElementById("overviewGrid").innerHTML=ov.join("");
  // Tables
  function tbl(id,rows,hdrs,wrapCol,gen){var ths=hdrs.map(function(h,i){return'<th data-col="'+i+'" onclick="doSort(\''+id+'\','+i+')">'+h+(currentSort.table===id&&currentSort.col===i?'<span class="sort-arrow">'+(currentSort.asc?"▲":"▼")+"</span>":"")+"</th>"});document.querySelector("#tbl-"+id+" thead").innerHTML="<tr>"+ths.join("")+"</tr>";var bd=[];rows.forEach(function(r,ri){var cls=wrapCol?"wrap":"";var cells=hdrs.map(function(h,i){var v=r[i]||"";if(gen)v=gen(i,v,r,ri);return"<td"+(wrapCol===i?" class='"+cls+"'":"")+">"+v+"</td>"});bd.push('<tr class="data-row" onclick="toggleRow(\''+id+'\','+ri+')">'+cells.join("")+"</tr>")});document.querySelector("#tbl-"+id+" tbody").innerHTML=bd.join("")}
  function fb(f){if(!f)return"";var s=String(f);if(s.indexOf("天")>=0||s.indexOf("日报")>=0)return"b-daily";if(s.indexOf("周")>=0||s.indexOf("周报")>=0)return"b-weekly";if(s.indexOf("月")>=0||s.indexOf("月报")>=0)return"b-monthly";return"b-other"}
  function lb(l){var s=String(l);if(s.indexOf("紧急")>=0||s.indexOf("高")>=0)return"badge b-high";if(s.indexOf("中")>=0)return"badge b-mid";return"badge b-low"}
  tbl("zibiao",zr,ss["自评表"].headers||[],-1,function(i,v){if(i===6)return'<span class="badge '+fb(v)+'">'+v+"</span>";if(i===9&&v)return'<span class="'+lb(v)+'">'+v+"</span>";return v});
  tbl("chaju",cr,ss["差距表"].headers||[],6,function(i,v){if(i===4)return'<span class="badge '+fb(v)+'">'+v+"</span>";if(i===8&&v)return'<span class="'+lb(v)+'">'+v+"</span>";return v});
  tbl("yichang",yr,ss["异常表"].headers||[],5,function(i,v){if(i===4)return'<span class="badge '+(String(v).indexOf("风险")>=0?"b-high":"b-mid")+'">'+v+"</span>";return v});
  tbl("baobiao",br,ss["报表清单"].headers||[],-1,function(i,v){if(i===2)return'<span class="badge '+fb(v)+'">'+v+"</span>";return v});
  tbl("jifen",jr,["排名"].concat(ss["积分表"].headers||[]),-1,function(i,v,r,ri){if(i===0){var total=parseInt(r[5]||0);var prevTotal=ri>0?parseInt(jr[ri-1][4]||0):-1;var rank=total===prevTotal&&ri>0?null:ri+1;return rank?"<strong>"+rank+"</strong>":""}return i===5?"<strong>"+v+"</strong>":v});
  ["zibiao","chaju","yichang","baobiao","jifen"].forEach(function(t){var rows={zibiao:zr,chaju:cr,yichang:yr,baobiao:br,jifen:jr}[t];document.getElementById("info-"+t).textContent="共 "+rows.length+" 条";var badge=document.querySelector('.tab[data-tab="'+t+'"] .tab-badge');if(badge)badge.textContent=rows.length});
  var projects=new Set(),people=new Set();zr.forEach(function(r){if(r[1]&&r[1]!=="项目名称")projects.add(r[1]);if(r[2]&&r[2]!=="填报人")people.add(r[2])});cr.forEach(function(r){if(r[2])people.add(r[2])});yr.forEach(function(r){if(r[2])people.add(r[2])});
  var manual=zr.filter(function(r){return(r[8]||"").indexOf("人工")>=0}).length;
  document.getElementById("sProj").textContent=projects.size;document.getElementById("sPeople").textContent=people.size;document.getElementById("sReport").textContent=zr.length;document.getElementById("sAnom").textContent=yr.length;document.getElementById("sGap").textContent=cr.length;document.getElementById("sSync").textContent=DATA.timestamp||"";
}
function switchTab(name){document.querySelectorAll(".tab").forEach(function(t){t.classList.remove("active")});document.querySelectorAll(".panel").forEach(function(p){p.classList.remove("active")});var tb=document.querySelector('.tab[data-tab="'+name+'"]');if(tb)tb.classList.add("active");var pn=document.getElementById("panel-"+name);if(pn)pn.classList.add("active")}
document.addEventListener("input",function(e){if(e.target.classList.contains("search-box")){var tbl=e.target.dataset.table,q=e.target.value.toLowerCase();var rows=document.querySelectorAll("#tbl-"+tbl+" tbody tr");var v=0;rows.forEach(function(r){var m=!q||r.textContent.toLowerCase().indexOf(q)>=0;r.style.display=m?"":"none";if(m)v++});document.getElementById("info-"+tbl).textContent=q?"匹配 "+v+" 条":"共 "+rows.length+" 条"}});
function doSort(tbl,col){var map={zibiao:"自评表",chaju:"差距表",yichang:"异常表",baobiao:"报表清单",jifen:"积分表"};if(!map[tbl])return;if(currentSort.table===tbl&&currentSort.col===col){currentSort.asc=!currentSort.asc}else{currentSort.table=tbl;currentSort.col=col;currentSort.asc=true}var rows=DATA.sheets[map[tbl]].rows.slice();rows.sort(function(a,b){var va=a[col]||"",vb=b[col]||"";if(!isNaN(va)&&!isNaN(vb)){va=Number(va);vb=Number(vb)}else{va=String(va);vb=String(vb);if(va<vb)return currentSort.asc?-1:1;if(va>vb)return currentSort.asc?1:-1;return 0}return currentSort.asc?va-vb:vb-va});DATA.sheets[map[tbl]].rows=rows;render()}
function toggleRow(tbl,ri){var tr=document.querySelectorAll("#tbl-"+tbl+" tbody tr")[ri];if(tr){tr.classList.toggle("expanded");var sheet={zibiao:"自评表",chaju:"差距表",yichang:"异常表",baobiao:"报表清单",jifen:"积分表"}[tbl];if(sheet){var r=DATA.sheets[sheet].rows[ri];if(r){var longest="";for(var i=0;i<r.length;i++){var v=String(r[i]||"");if(v.length>longest.length)longest=v}tr.title=tr.classList.contains("expanded")?longest.substring(0,500):""}}}}
function doRefresh(){var b=document.getElementById("refreshBtn"),d=document.getElementById("syncDot");b.textContent="⏳ 同步中…";b.classList.add("loading");d.classList.add("stale");document.getElementById("syncLabel").textContent="同步中…";fetch("data.json?t="+Date.now()).then(function(r){return r.json()}).then(function(dd){DATA=dd;render();b.textContent="✅ 已同步";b.classList.remove("loading");d.classList.remove("stale");document.getElementById("syncLabel").textContent="已同步";document.getElementById("sSync").textContent=dd.timestamp||"";setTimeout(function(){b.textContent="🔄 刷新数据"},2500)}).catch(function(){b.textContent="❌ 失败";b.classList.remove("loading");document.getElementById("syncLabel").textContent="同步失败";setTimeout(function(){b.textContent="🔄 刷新数据"},2500)})}
document.addEventListener("DOMContentLoaded",function(){document.getElementById("tabbar").addEventListener("click",function(e){var b=e.target.closest(".tab");if(b){var t=b.getAttribute("data-tab");if(t)switchTab(t)}});render();document.getElementById("syncDot").classList.remove("stale");document.getElementById("syncLabel").textContent="已加载"});
</script>
</body>
</html>
