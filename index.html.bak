<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>一心通营 · 远程操控系统</title>
<style>
/* ===== 一心通营 Design System ===== */
:root{
  --bg:#f4f6fa;--bg2:#e8ecf2;--surface:#fff;--raised:#f8f9fc;--overlay:#eef1f6;
  --border:#dfe3ea;--border-light:#edf0f5;
  --t1:#1a1f2e;--t2:#4a5568;--t3:#8b95a8;
  --blue:#3b6df0;--blue-light:#e8f0ff;--teal:#0ea5b9;--teal-light:#e6f7f9;
  --green:#10b981;--green-light:#ecfdf5;--amber:#f59e0b;--amber-light:#fffbeb;
  --red:#ef4444;--red-light:#fef2f2;--purple:#8b5cf6;--purple-light:#f5f3ff;
  --cyan:#0891b2;
  --radius:8px;--radius-lg:12px;--radius-xl:16px;
  --shadow-sm:0 1px 3px rgba(0,0,0,.04);--shadow:0 2px 8px rgba(0,0,0,.06);--shadow-lg:0 4px 16px rgba(0,0,0,.08);
  --font:"Inter",-apple-system,"Segoe UI","PingFang SC","Microsoft YaHei",sans-serif;--mono:"JetBrains Mono","SF Mono",monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px}body{font-family:var(--font);background:var(--bg);color:var(--t1);line-height:1.6;-webkit-font-smoothing:antialiased}

/* ===== TOP BAR ===== */
.topbar{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.85);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);padding:0 28px;height:56px;display:flex;align-items:center;justify-content:space-between}
.topbar-l{display:flex;align-items:center;gap:12px}
.logo{width:36px;height:36px;background:linear-gradient(135deg,var(--blue),var(--teal));border-radius:10px;display:grid;place-items:center;font-weight:800;font-size:16px;color:#fff;box-shadow:0 2px 8px rgba(59,109,240,.3)}
.brand{font-size:17px;font-weight:700;letter-spacing:.5px}.brand span{color:var(--blue)}
.topbar-r{display:flex;align-items:center;gap:16px;font-size:12px;color:var(--t3)}
.sync-dot{width:7px;height:7px;background:var(--green);border-radius:50%;box-shadow:0 0 6px rgba(16,185,129,.4)}
.sync-dot.stale{background:var(--amber)}
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 16px;border:1px solid var(--border);border-radius:20px;background:var(--surface);color:var(--t2);font-size:12px;font-weight:600;cursor:pointer;transition:all .2s;box-shadow:var(--shadow-sm)}
.btn:hover{background:var(--blue-light);border-color:var(--blue);color:var(--blue);box-shadow:var(--shadow)}
.btn-primary{background:var(--blue);border-color:var(--blue);color:#fff}.btn-primary:hover{background:#2b5de0;color:#fff}
.btn.loading{opacity:.6;pointer-events:none}

/* ===== STATS ROW ===== */
.statbar{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;padding:20px 28px}
.stat{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:18px 22px;box-shadow:var(--shadow-sm);transition:all .2s;cursor:default}
.stat:hover{box-shadow:var(--shadow);transform:translateY(-1px)}
.stat-label{font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;font-weight:600}
.stat-value{font-size:30px;font-weight:800;font-family:var(--mono);line-height:1;letter-spacing:-1px}
.stat-sub{font-size:11px;color:var(--t3);margin-top:6px}
.stat.anomalies .stat-value{color:var(--red)}.stat.gaps .stat-value{color:var(--amber)}
.stat.reports .stat-value{color:var(--blue)}.stat.people .stat-value{color:var(--teal)}
.stat.projects .stat-value{color:var(--purple)}.stat.sync .stat-value{color:var(--green);font-size:15px}

/* ===== SCOREBOARD ===== */
.scoreboard{margin:0 28px 18px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-xl);padding:22px 28px;box-shadow:var(--shadow)}
.sb-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.sb-title{font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px}
.sb-meta{display:flex;gap:20px;font-size:12px;color:var(--t3)}.sb-meta strong{color:var(--t1);font-family:var(--mono)}
.podium{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:10px}
.person{background:var(--raised);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px;text-align:center;transition:all .2s;cursor:pointer}
.person:hover{box-shadow:var(--shadow-lg);transform:translateY(-2px)}
.person.gold{border-color:#f0c850;background:linear-gradient(180deg,#fffdf5,#fff9e6);box-shadow:0 4px 20px rgba(240,200,80,.2)}
.person.silver{border-color:#c0c8d4;background:linear-gradient(180deg,#f8f9fc,#f0f2f6);box-shadow:0 4px 16px rgba(160,170,190,.15)}
.person.bronze{border-color:#d4a874;background:linear-gradient(180deg,#fdf8f2,#f8efe4);box-shadow:0 4px 12px rgba(210,160,110,.12)}
.person .p-score{font-size:22px;font-weight:800;font-family:var(--mono);margin-top:6px;color:var(--t1)}
.person.gold .p-score{color:#c8940a}.person.silver .p-score{color:#6b7280}.person.bronze .p-score{color:#a06830}
.p-avatar{width:44px;height:44px;border-radius:50%;margin:0 auto 10px;display:grid;place-items:center;font-weight:700;font-size:16px;color:#fff}
.p-name{font-size:14px;font-weight:700}.p-title{font-size:11px;color:var(--t3);margin-top:3px}

/* ===== TABS ===== */
.tabbar{display:flex;gap:4px;margin:0 28px;border-bottom:1px solid var(--border);position:sticky;top:56px;z-index:40;background:var(--bg);padding-top:4px}
.tab{position:relative;padding:10px 18px;background:none;border:none;color:var(--t2);font-size:13px;font-weight:500;cursor:pointer;transition:all .2s;border-radius:var(--radius) var(--radius) 0 0)}
.tab:hover{color:var(--t1);background:var(--surface)}
.tab:focus-visible{outline:2px solid var(--blue);outline-offset:-2px}
.tab.active{color:var(--blue);font-weight:600;background:var(--surface)}
.tab.active::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:2px;background:var(--blue);border-radius:1px}
.tab-badge{display:inline-block;margin-left:6px;padding:1px 7px;border-radius:10px;font-size:10px;background:var(--border-light);color:var(--t3);font-weight:500}.tab.active .tab-badge{background:var(--blue-light);color:var(--blue)}

/* ===== PANELS ===== */
.panels{margin:0 28px 40px;padding-top:16px}
.panel{display:none;animation:fadeIn .25s ease}.panel.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* ===== TOOLBAR ===== */
.toolbar{display:flex;gap:8px;align-items:center;margin-bottom:12px;flex-wrap:wrap}
.search-box{flex:1;min-width:200px;max-width:340px;padding:8px 14px;background:var(--surface);border:1px solid var(--border);border-radius:20px;color:var(--t1);font-size:13px;outline:none;transition:.2s;box-shadow:var(--shadow-sm)}
.search-box:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(59,109,240,.1)}.search-box::placeholder{color:var(--t3)}
.sort-btn{padding:7px 14px;background:var(--surface);border:1px solid var(--border);border-radius:20px;color:var(--t2);font-size:11px;cursor:pointer;white-space:nowrap;transition:.2s;font-weight:500}
.sort-btn:hover{border-color:var(--blue);color:var(--blue)}.sort-btn.active{background:var(--blue-light);border-color:var(--blue);color:var(--blue)}
.count-info{font-size:12px;color:var(--t3);margin-left:auto;white-space:nowrap;font-family:var(--mono)}

/* ===== TABLE ===== */
.table-wrap{border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;max-height:68vh;overflow-y:auto;background:var(--surface);box-shadow:var(--shadow-sm)}
table{width:100%;border-collapse:collapse;font-size:13px}
thead{position:sticky;top:0;z-index:2}
th{background:var(--raised);padding:10px 14px;text-align:left;font-weight:600;color:var(--t2);font-size:11px;letter-spacing:.3px;white-space:nowrap;border-bottom:2px solid var(--border);cursor:pointer;user-select:none;transition:.15s}
th:hover{color:var(--blue);background:#f0f4ff}
th .sort-arrow{margin-left:3px;opacity:.3;font-size:10px}th:hover .sort-arrow{opacity:1}
td{padding:8px 14px;border-bottom:1px solid var(--border-light);color:var(--t1);white-space:nowrap;max-width:300px;overflow:hidden;text-overflow:ellipsis}
td.wrap{white-space:normal;max-width:400px;font-size:12px;line-height:1.5}
tr.data-row{cursor:pointer;transition:.08s}tr.data-row:hover{background:var(--blue-light)}
tr.data-row.expanded{background:var(--raised)}

/* badges */
.badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600;line-height:1.5}
.b-daily{background:var(--blue-light);color:var(--blue)}.b-weekly{background:var(--purple-light);color:var(--purple)}
.b-monthly{background:var(--green-light);color:var(--green)}.b-other{background:var(--border-light);color:var(--t2)}
.b-high{background:var(--red-light);color:var(--red)}.b-mid{background:var(--amber-light);color:var(--amber)}
.b-low{background:var(--border-light);color:var(--t3)}

/* ===== OVERVIEW GRID ===== */
.overview-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px}
.ov-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px;cursor:pointer;transition:all .2s;box-shadow:var(--shadow-sm)}
.ov-card:hover{box-shadow:var(--shadow);transform:translateY(-2px)}
.ov-header{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px}
.ov-name{font-size:15px;font-weight:700}.ov-people{font-size:11px;color:var(--t3)}
.ov-metrics{display:flex;gap:8px;flex-wrap:wrap}
.ov-metric{display:flex;flex-direction:column;align-items:center;padding:8px 14px;background:var(--raised);border-radius:var(--radius);min-width:60px}
.ov-metric .val{font-family:var(--mono);font-weight:700;font-size:16px}.ov-metric .lbl{font-size:10px;color:var(--t3);margin-top:2px}

/* ===== EMPTY / LOADING ===== */
.empty{text-align:center;padding:60px 20px;color:var(--t3)}.empty-icon{font-size:40px;margin-bottom:12px}

.footer{text-align:center;padding:16px;color:var(--t3);font-size:11px;border-top:1px solid var(--border);margin-top:auto;background:var(--surface)}

@media(max-width:1200px){.statbar{grid-template-columns:repeat(3,1fr)}}
@media(max-width:768px){.statbar{grid-template-columns:repeat(2,1fr)}.tab{padding:8px 12px;font-size:12px}.topbar{padding:0 16px}}
</style>
</head>
<body>
<div class="topbar"><div class="topbar-l"><div class="logo">通</div><div class="brand">一心通营 · <span>远程操控系统</span></div></div><div class="topbar-r"><span class="sync-dot" id="syncDot"></span><span id="syncLabel">就绪</span><button class="btn btn-primary" id="refreshBtn" onclick="doRefresh()">🔄 同步数据</button></div></div>

<div class="statbar">
<div class="stat projects"><div class="stat-label">总项目</div><div class="stat-value" id="sProj">-</div><div class="stat-sub">大亚湾 · 揭阳 · 中山 · 古雷 · 裕龙</div></div>
<div class="stat people"><div class="stat-label">运营人员</div><div class="stat-value" id="sPeople">-</div><div class="stat-sub">全项目运营团队</div></div>
<div class="stat reports"><div class="stat-label">报告总数</div><div class="stat-value" id="sReport">-</div><div class="stat-sub">日报 · 周报 · 月报</div></div>
<div class="stat anomalies"><div class="stat-label">异常事件</div><div class="stat-value" id="sAnom">-</div><div class="stat-sub">数据 · 风险 · 功能</div></div>
<div class="stat gaps"><div class="stat-label">功能差距</div><div class="stat-value" id="sGap">-</div><div class="stat-sub">待优化项</div></div>
<div class="stat sync"><div class="stat-label">同步方式</div><div class="stat-value" style="font-family:var(--font);font-weight:700">飞书 API</div><div class="stat-sub" id="sSync">云文档直连</div></div>
</div>

<div class="scoreboard"><div class="sb-header"><div class="sb-title">🏆 运营积分榜</div><div class="sb-meta"><span>总计 <strong id="sbt">0</strong> 人</span><span>有效积分 <strong id="sbp">0</strong> 人</span></div></div><div class="podium" id="podium"></div></div>

<div class="tabbar" id="tabbar">
<button class="tab active" data-tab="overview">📊 总览</button>
<button class="tab" data-tab="zibiao">📋 自评表<span class="tab-badge">0</span></button>
<button class="tab" data-tab="chaju">⚠ 差距表<span class="tab-badge">0</span></button>
<button class="tab" data-tab="yichang">🚨 异常表<span class="tab-badge">0</span></button>
<button class="tab" data-tab="baobiao">📑 清单<span class="tab-badge">0</span></button>
<button class="tab" data-tab="jifen">🏆 积分表<span class="tab-badge">0</span></button>
</div>

<div class="panels">
<div id="panel-overview" class="panel active"><div class="overview-grid" id="overviewGrid"></div></div>
<div id="panel-zibiao" class="panel"><div class="toolbar"><input class="search-box" placeholder="搜索自评表…" data-table="zibiao"><button class="sort-btn" data-table="zibiao" data-col="6">按频率</button><button class="sort-btn" data-table="zibiao" data-col="1">按项目</button><button class="sort-btn" data-table="zibiao" data-col="2">按人员</button><span class="count-info" id="info-zibiao"></span></div><div class="table-wrap"><table id="tbl-zibiao"><thead></thead><tbody></tbody></table></div></div>
<div id="panel-chaju" class="panel"><div class="toolbar"><input class="search-box" placeholder="搜索差距表…" data-table="chaju"><button class="sort-btn" data-table="chaju" data-col="4">按频率</button><button class="sort-btn" data-table="chaju" data-col="1">按项目</button><button class="sort-btn" data-table="chaju" data-col="8">按等级</button><span class="count-info" id="info-chaju"></span></div><div class="table-wrap"><table id="tbl-chaju"><thead></thead><tbody></tbody></table></div></div>
<div id="panel-yichang" class="panel"><div class="toolbar"><input class="search-box" placeholder="搜索异常表…" data-table="yichang"><button class="sort-btn" data-table="yichang" data-col="4">按类型</button><button class="sort-btn" data-table="yichang" data-col="1">按项目</button><span class="count-info" id="info-yichang"></span></div><div class="table-wrap"><table id="tbl-yichang"><thead></thead><tbody></tbody></table></div></div>
<div id="panel-baobiao" class="panel"><div class="toolbar"><input class="search-box" placeholder="搜索报表清单…" data-table="baobiao"><button class="sort-btn" data-table="baobiao" data-col="0">按园区</button><button class="sort-btn" data-table="baobiao" data-col="2">按频率</button><span class="count-info" id="info-baobiao"></span></div><div class="table-wrap"><table id="tbl-baobiao"><thead></thead><tbody></tbody></table></div></div>
<div id="panel-jifen" class="panel"><div class="toolbar"><input class="search-box" placeholder="搜索积分表…" data-table="jifen"><button class="sort-btn" data-table="jifen" data-col="4">按总积分</button><button class="sort-btn" data-table="jifen" data-col="0">按姓名</button><span class="count-info" id="info-jifen"></span></div><div class="table-wrap"><table id="tbl-jifen"><thead></thead><tbody></tbody></table></div></div>
</div>

<div class="footer">一心通营远程操控系统 · 数据源：飞书云文档「三张表 副本」</div>


